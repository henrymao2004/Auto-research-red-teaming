# claude_code victim base image.
# Build tag: ar_claude_code_base:latest.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates gnupg \
    python3 python3-pip \
    git jq \
 && rm -rf /var/lib/apt/lists/*

# Node runtime
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/*

# Python deps
RUN pip3 install --no-cache-dir --timeout 120 --retries 5 \
    -i https://pypi.tuna.tsinghua.edu.cn/simple \
    claude-agent-sdk==0.2.87 \
    anyio \
    mcp

# Runner files
COPY runner_core.py /app/runner_core.py
COPY in_container_runner.py /app/in_container_runner.py

# Non-root agent user
RUN useradd -m -s /bin/bash agent \
 && mkdir -p /work /home/agent/.claude /home/agent/.config /home/agent/.npm \
 && chown -R agent:agent /work /app /home/agent

# Agent home
ENV HOME=/home/agent

USER agent
WORKDIR /work

# Victim entrypoint
ENTRYPOINT ["python3", "/app/in_container_runner.py"]
