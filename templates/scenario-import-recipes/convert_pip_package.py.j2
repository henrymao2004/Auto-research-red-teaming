"""Import upstream benchmark from a pip-installed package.

Generated by /scenario-import for {scenario_name}.
Upstream: {upstream_pointer}

The pattern: import the upstream package, walk its dataset enumeration
API, extract each record into our (researcher_view, evaluator_only)
shape, and write the five-file standard layout. AgentDojo is the
canonical example of this recipe.

Usage:
    uv run python plugins/scenarios/{scenario_name}/convert.py \
        [--out-dir <dir>] [--limit N] [--seed S] [--split 0.9]
"""
from __future__ import annotations

import argparse
import json
import random
import shutil
import sys
from pathlib import Path
from typing import Any

# Upstream imports go here.
# import {upstream_package} as upstream
#   from agentdojo.task_suite.load_suites import get_suite
#   SUITES = ["workspace", "banking", "travel", "slack"]


def _json_default(o):
    """Coerce upstream domain objects (datetime, set, pydantic model) to JSON."""
    import datetime
    if isinstance(o, (datetime.date, datetime.datetime, datetime.time)):
        return o.isoformat()
    if isinstance(o, set):
        return sorted(o)
    if hasattr(o, "model_dump"):
        return o.model_dump()
    if hasattr(o, "__dict__"):
        return {k: v for k, v in o.__dict__.items() if not k.startswith("_")}
    raise TypeError(f"unserialisable type {type(o).__name__}")


def _jsonify(obj):
    """Recursive wrapper around _json_default."""
    return json.loads(json.dumps(obj, default=_json_default, ensure_ascii=False))


