    """Translate ONE upstream record into our (researcher_view, evaluator_only) pair.

    Returns: {
        "id": <int>,                         # filled by caller, NOT here
        "category": "<cat>",                 # caller fills if needed
        "researcher_view": {<fields>...},    # MUST match contract.researcher_visible_fields
        "evaluator_only": {<fields>...},     # MUST match contract.evaluator_only_fields
    }
    """
    # Fill from upstream schema.
    researcher_view = {
    }
    evaluator_only = {
    }
    return {"researcher_view": researcher_view, "evaluator_only": evaluator_only}


def enumerate_upstream() -> list[tuple[str, Any]]:
    """Walk the upstream package and yield (category, record) pairs.

    For benchmarks with a single category, just yield ('default', record).
    For multi-suite benchmarks (e.g. AgentDojo), yield one (suite, pair) per
    cartesian product as AgentDojo's convert.py does.
    """
    records: list[tuple[str, Any]] = []
    # Replace with benchmark-specific enumeration.
    return records


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("--out-dir", default=str(Path(__file__).resolve().parent),
                   help="Where to write clean/, train.json, etc.")
    p.add_argument("--limit", type=int, default=None, help="Cap total records (sample mode).")
    p.add_argument("--seed", type=int, default=0)
    p.add_argument("--split", type=float, default=0.9, help="Stage-1 ratio for stratified split.")
    args = p.parse_args()

    out = Path(args.out_dir).resolve()
    (out / "clean").mkdir(parents=True, exist_ok=True)
    (out / "clean_heldout").mkdir(parents=True, exist_ok=True)

    raw = enumerate_upstream()
    if args.limit:
        raw = raw[: args.limit]
    if not raw:
        print("ERROR: enumerate_upstream() returned 0 records", file=sys.stderr)
        return 2

    # Assign ids.
    instances: list[dict[str, Any]] = []
    for i, (cat, rec) in enumerate(raw, start=1):
        extracted = extract_one_record(rec, cat)
        instances.append({
            "id": i,
            "category": cat,
            "researcher_view": _jsonify(extracted["researcher_view"]),
            "evaluator_only": _jsonify(extracted["evaluator_only"]),
        })

    # Stratified random split
    rng = random.Random(args.seed)
    by_cat: dict[str, list[dict]] = {}
    for inst in instances:
        by_cat.setdefault(inst["category"], []).append(inst)

    train_ids: dict[str, list[int]] = {}
    heldout_ids: dict[str, list[int]] = {}
    for cat, items in by_cat.items():
        rng.shuffle(items)
        n = len(items)
        if n >= 2:
            n_train = max(1, min(n - 1, round(args.split * n)))
        else:
            n_train = n
        train_ids[cat] = [i["id"] for i in items[:n_train]]
        heldout_ids[cat] = [i["id"] for i in items[n_train:]]

    # Write outputs.
    judge_data: dict[str, dict] = {}
    for inst in instances:
        rv = dict(inst["researcher_view"])
        rv.setdefault("id", inst["id"])
        rv.setdefault("category", inst["category"])
        side = "clean" if inst["id"] in train_ids[inst["category"]] else "clean_heldout"
        cat_dir = out / side / inst["category"]
        cat_dir.mkdir(parents=True, exist_ok=True)
        (cat_dir / f"{inst['id']}.json").write_text(
            json.dumps(rv, ensure_ascii=False, indent=2, default=_json_default) + "\n"
        )
        # Merge judge-only fields.
        merged = {**rv, **inst["evaluator_only"]}
        judge_data[str(inst["id"])] = merged

    (out / "judge_data.json").write_text(
        json.dumps(judge_data, ensure_ascii=False, indent=2, default=_json_default) + "\n"
    )

    def _split_blob(ids_map: dict[str, list[int]], key: str) -> dict:
        return {
            "seed": args.seed,
            "split_method": "stratified_random",
            "categories": {
                cat: {"total": len(by_cat[cat]), key: sorted(ids)}
                for cat, ids in ids_map.items()
            },
        }

    (out / "train.json").write_text(
        json.dumps(_split_blob(train_ids, "train"), indent=2, ensure_ascii=False) + "\n"
    )
    if any(heldout_ids.values()):
        (out / "heldout.json").write_text(
            json.dumps(_split_blob(heldout_ids, "held_out"), indent=2, ensure_ascii=False) + "\n"
        )

    train_total = sum(len(v) for v in train_ids.values())
    heldout_total = sum(len(v) for v in heldout_ids.values())
    print(f"done: stage1={train_total} heldout={heldout_total} categories={len(by_cat)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
