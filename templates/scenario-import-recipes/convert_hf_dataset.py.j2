"""Import upstream benchmark from a HuggingFace dataset.

Generated by /scenario-import for {scenario_name}.
Upstream: huggingface://{upstream_pointer}

The pattern: `datasets.load_dataset(name, split=...)`, then map each
row's fields into our (researcher_view, evaluator_only) shape. HF
datasets often ship their own official split — **respect it** if
present (do not randomly resplit a published benchmark).

Usage:
    uv run python plugins/scenarios/{scenario_name}/convert.py \
        [--out-dir <dir>] [--limit N]
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any

# Dependency: datasets.
from datasets import load_dataset  # type: ignore


UPSTREAM_HF_ID = "{upstream_pointer}"   # e.g. "PKU-Alignment/BeaverTails"


def _json_default(o):
    import datetime
    if isinstance(o, (datetime.date, datetime.datetime, datetime.time)):
        return o.isoformat()
    if isinstance(o, set):
        return sorted(o)
    if hasattr(o, "model_dump"):
        return o.model_dump()
    if hasattr(o, "__dict__"):
        return {k: v for k, v in o.__dict__.items() if not k.startswith("_")}
    raise TypeError(f"unserialisable type {type(o).__name__}")


def _jsonify(obj):
    return json.loads(json.dumps(obj, default=_json_default, ensure_ascii=False))


def extract_one_record(row: dict, category: str) -> dict[str, Any]:
    """Map ONE HF row into (researcher_view, evaluator_only)."""
    # Map row keys into visible/private halves.
    researcher_view: dict[str, Any] = {}
    evaluator_only: dict[str, Any] = {}
    return {"researcher_view": researcher_view, "evaluator_only": evaluator_only}


def categorize(row: dict) -> str:
    """Return the row's category. Use a single 'default' if benchmark is flat."""
    return row.get("category", "default")


def enumerate_upstream() -> tuple[list[tuple[str, dict]], list[tuple[str, dict]]]:
    """Return (train_records, heldout_records) using upstream's split."""
    train_ds = load_dataset(UPSTREAM_HF_ID, split="train")
    train = [(categorize(r), dict(r)) for r in train_ds]

    # Load held-out split if present.
    try:
        held_ds = load_dataset(UPSTREAM_HF_ID, split="test")
    except (ValueError, FileNotFoundError):
        held_ds = []
    held = [(categorize(r), dict(r)) for r in held_ds]
    return train, held


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("--out-dir", default=str(Path(__file__).resolve().parent))
    p.add_argument("--limit", type=int, default=None,
                   help="Cap total records across both splits.")
    args = p.parse_args()

    out = Path(args.out_dir).resolve()
    (out / "clean").mkdir(parents=True, exist_ok=True)
    (out / "clean_heldout").mkdir(parents=True, exist_ok=True)

    train_raw, held_raw = enumerate_upstream()
    if args.limit:
        # Preserve split ratio.
        ratio = len(train_raw) / max(1, len(train_raw) + len(held_raw))
        n_train = int(args.limit * ratio)
        train_raw = train_raw[:n_train]
        held_raw = held_raw[: args.limit - n_train]

    if not train_raw and not held_raw:
        print(f"ERROR: no rows loaded from {UPSTREAM_HF_ID}", file=sys.stderr)
        return 2

    out = Path(args.out_dir).resolve()
    (out / "clean").mkdir(parents=True, exist_ok=True)
    (out / "clean_heldout").mkdir(parents=True, exist_ok=True)

    instances: list[dict[str, Any]] = []
    next_id = 1
    for split_name, rows in (("train", train_raw), ("held_out", held_raw)):
        for cat, row in rows:
            extracted = extract_one_record(row, cat)
            instances.append({
                "id": next_id,
                "category": cat,
                "split": split_name,
                "researcher_view": _jsonify(extracted["researcher_view"]),
                "evaluator_only": _jsonify(extracted["evaluator_only"]),
            })
            next_id += 1

    by_cat: dict[str, list[dict]] = {}
    train_ids: dict[str, list[int]] = {}
    heldout_ids: dict[str, list[int]] = {}
    for inst in instances:
        cat = inst["category"]
        by_cat.setdefault(cat, []).append(inst)
        if inst["split"] == "train":
            train_ids.setdefault(cat, []).append(inst["id"])
            heldout_ids.setdefault(cat, [])
        else:
            heldout_ids.setdefault(cat, []).append(inst["id"])
            train_ids.setdefault(cat, [])

    judge_data: dict[str, dict] = {}
    for inst in instances:
        rv = dict(inst["researcher_view"])
        rv.setdefault("id", inst["id"])
        rv.setdefault("category", inst["category"])
        side = "clean" if inst["split"] == "train" else "clean_heldout"
        cat_dir = out / side / inst["category"]
        cat_dir.mkdir(parents=True, exist_ok=True)
        (cat_dir / f"{inst['id']}.json").write_text(
            json.dumps(rv, ensure_ascii=False, indent=2, default=_json_default) + "\n"
        )
        merged = {**rv, **inst["evaluator_only"]}
        judge_data[str(inst["id"])] = merged

    (out / "judge_data.json").write_text(
        json.dumps(judge_data, ensure_ascii=False, indent=2, default=_json_default) + "\n"
    )

    def _split_blob(ids_map: dict[str, list[int]], key: str) -> dict:
        return {
            "seed": None,
            "split_method": "upstream",
            "categories": {
                cat: {"total": len(by_cat[cat]), key: sorted(ids)}
                for cat, ids in ids_map.items()
            },
        }

    (out / "train.json").write_text(
        json.dumps(_split_blob(train_ids, "train"), indent=2, ensure_ascii=False) + "\n"
    )
    if any(heldout_ids.values()):
        (out / "heldout.json").write_text(
            json.dumps(_split_blob(heldout_ids, "held_out"), indent=2, ensure_ascii=False) + "\n"
        )

    train_total = sum(len(v) for v in train_ids.values())
    heldout_total = sum(len(v) for v in heldout_ids.values())
    print(f"done: stage1={train_total} heldout={heldout_total} categories={len(by_cat)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
