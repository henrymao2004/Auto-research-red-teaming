"""Import upstream benchmark from local files (JSONL / CSV / dir-of-JSON).

Generated by /scenario-import for {scenario_name}.
Upstream: {upstream_pointer}

The pattern: point at a local file (or directory) the user has staged,
detect the file format, iterate rows/files, map each into
(researcher_view, evaluator_only). Use this recipe when the benchmark
isn't on PyPI, github, or HF — e.g. an internal benchmark from a CSV.

Usage:
    uv run python plugins/scenarios/{scenario_name}/convert.py \
        --source <path-to-file-or-dir> \
        [--out-dir <dir>] [--limit N] [--seed S] [--split 0.9]
"""
from __future__ import annotations

import argparse
import csv
import json
import random
import sys
from pathlib import Path
from typing import Any, Iterable


def _detect_format(p: Path) -> str:
    if p.is_dir():
        return "json_dir"
    suffix = p.suffix.lower()
    if suffix == ".jsonl":
        return "jsonl"
    if suffix == ".json":
        return "json"
    if suffix == ".csv":
        return "csv"
    raise ValueError(f"unrecognised format for {p}")


def _iter_jsonl(p: Path) -> Iterable[dict]:
    with p.open() as f:
        for line in f:
            if line.strip():
                yield json.loads(line)


def _iter_json(p: Path) -> Iterable[dict]:
    data = json.loads(p.read_text())
    if isinstance(data, list):
        yield from data
    elif isinstance(data, dict):
        # Supported dict layouts.
        if "records" in data and isinstance(data["records"], list):
            yield from data["records"]
        else:
            for k, v in data.items():
                if isinstance(v, dict):
                    yield {"id": k, **v}


def _iter_csv(p: Path) -> Iterable[dict]:
    with p.open(newline="") as f:
        for row in csv.DictReader(f):
            yield dict(row)


def _iter_json_dir(p: Path) -> Iterable[dict]:
    for f in sorted(p.glob("**/*.json")):
        yield json.loads(f.read_text())


def extract_one_record(row: dict, category: str) -> dict[str, Any]:
    """Translate ONE upstream record into (researcher_view, evaluator_only)."""
    # Map fields into visible/private halves.
    researcher_view: dict[str, Any] = {}
    evaluator_only: dict[str, Any] = {}
    return {"researcher_view": researcher_view, "evaluator_only": evaluator_only}


def enumerate_upstream(source: Path) -> list[tuple[str, dict]]:
    fmt = _detect_format(source)
    if fmt == "jsonl":
        it = _iter_jsonl(source)
    elif fmt == "json":
        it = _iter_json(source)
    elif fmt == "csv":
        it = _iter_csv(source)
    else:  # json_dir
        it = _iter_json_dir(source)
    out: list[tuple[str, dict]] = []
    for row in it:
        cat = row.get("category") or row.get("class") or "default"
        out.append((cat, row))
    return out


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("--source", required=True, type=Path,
                   help="Path to JSONL / JSON / CSV file, or directory of JSONs.")
    p.add_argument("--out-dir", default=str(Path(__file__).resolve().parent))
    p.add_argument("--limit", type=int, default=None)
    p.add_argument("--seed", type=int, default=0)
    p.add_argument("--split", type=float, default=0.9)
    args = p.parse_args()

    raw = enumerate_upstream(args.source)
    if args.limit:
        raw = raw[: args.limit]
    if not raw:
        print(f"ERROR: 0 records parsed from {args.source}", file=sys.stderr)
        return 2

    out = Path(args.out_dir).resolve()
    (out / "clean").mkdir(parents=True, exist_ok=True)
    (out / "clean_heldout").mkdir(parents=True, exist_ok=True)

    def _json_default(o):
        import datetime
        if isinstance(o, (datetime.date, datetime.datetime, datetime.time)):
            return o.isoformat()
        if isinstance(o, set):
            return sorted(o)
        if hasattr(o, "model_dump"):
            return o.model_dump()
        if hasattr(o, "__dict__"):
            return {k: v for k, v in o.__dict__.items() if not k.startswith("_")}
        raise TypeError(f"unserialisable type {type(o).__name__}")

    def _jsonify(obj):
        return json.loads(json.dumps(obj, default=_json_default, ensure_ascii=False))

    instances: list[dict[str, Any]] = []
    for i, (cat, rec) in enumerate(raw, start=1):
        extracted = extract_one_record(rec, cat)
        instances.append({
            "id": i,
            "category": cat,
            "researcher_view": _jsonify(extracted["researcher_view"]),
            "evaluator_only": _jsonify(extracted["evaluator_only"]),
        })

    rng = random.Random(args.seed)
    by_cat: dict[str, list[dict]] = {}
    for inst in instances:
        by_cat.setdefault(inst["category"], []).append(inst)

    train_ids: dict[str, list[int]] = {}
    heldout_ids: dict[str, list[int]] = {}
    for cat, items in by_cat.items():
        rng.shuffle(items)
        n = len(items)
        if n >= 2:
            n_train = max(1, min(n - 1, round(args.split * n)))
        else:
            n_train = n
        train_ids[cat] = [i["id"] for i in items[:n_train]]
        heldout_ids[cat] = [i["id"] for i in items[n_train:]]

    judge_data: dict[str, dict] = {}
    for inst in instances:
        rv = dict(inst["researcher_view"])
        rv.setdefault("id", inst["id"])
        rv.setdefault("category", inst["category"])
        side = "clean" if inst["id"] in train_ids[inst["category"]] else "clean_heldout"
        cat_dir = out / side / inst["category"]
        cat_dir.mkdir(parents=True, exist_ok=True)
        (cat_dir / f"{inst['id']}.json").write_text(
            json.dumps(rv, ensure_ascii=False, indent=2, default=_json_default) + "\n"
        )
        merged = {**rv, **inst["evaluator_only"]}
        judge_data[str(inst["id"])] = merged

    (out / "judge_data.json").write_text(
        json.dumps(judge_data, ensure_ascii=False, indent=2, default=_json_default) + "\n"
    )

    def _split_blob(ids_map: dict[str, list[int]], key: str) -> dict:
        return {
            "seed": args.seed,
            "split_method": "stratified_random",
            "categories": {
                cat: {"total": len(by_cat[cat]), key: sorted(ids)}
                for cat, ids in ids_map.items()
            },
        }

    (out / "train.json").write_text(
        json.dumps(_split_blob(train_ids, "train"), indent=2, ensure_ascii=False) + "\n"
    )
    if any(heldout_ids.values()):
        (out / "heldout.json").write_text(
            json.dumps(_split_blob(heldout_ids, "held_out"), indent=2, ensure_ascii=False) + "\n"
        )

    train_total = sum(len(v) for v in train_ids.values())
    heldout_total = sum(len(v) for v in heldout_ids.values())
    print(f"done: stage1={train_total} heldout={heldout_total} categories={len(by_cat)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
