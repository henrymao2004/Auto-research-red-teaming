# Endpoint slots: VICTIM, JUDGE, GENERATOR.
# Run `/setup` or copy to `.env`.
# Protocol follows each BASE_URL.


# Optional unified provider.
# UNIFIED_API_KEY=sk-...
# UNIFIED_PROVIDER=openrouter


# Victim endpoint.
# Must serve Anthropic /v1/messages.
VICTIM_BASE_URL=https://api.deepseek.com/anthropic
VICTIM_API_KEY=sk-PLACEHOLDER_VICTIM_KEY
VICTIM_MODEL=deepseek-v4-pro        # default; --model overrides


# Researcher backbone.
# Leave unset for host Claude auth.
#   RESEARCHER_MODEL=qwen/qwen3.7-max
#   RESEARCHER_BASE_URL=https://openrouter.ai/api
#   RESEARCHER_API_KEY=sk-or-...        # or OPENROUTER_API_KEY
# RESEARCHER_API_KEY=sk-or-PLACEHOLDER_RESEARCHER_KEY


# Judge endpoint.
# OpenAI-compatible.
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_API_KEY=PLACEHOLDER_OPENROUTER_KEY
JUDGE_MODEL=google/gemini-3-flash-preview


# Scenario-build generator endpoint.
# OpenAI-compatible.
ROUTER_BASE_URL=https://api.openai.com/v1
ROUTER_API_KEY=sk-PLACEHOLDER_OPENAI_KEY
GENERATOR_MODEL=gpt-5

# API call delay.
# INSTANTIATOR_SLEEP=0.2
